# Zenith Configuration Template
# Copy this file to .env and fill in the values

# General App Config
ZENITH_PORT=50051

# Database Config (CockroachDB Serverless)
# Format: cockroachdb://<user>:<password>@<host>:<port>/<database>?sslmode=verify-full&x-migrations-lock=false
DATABASE_URL=cockroachdb://user:password@host:26257/defaultdb?sslmode=verify-full&x-migrations-lock=false

# DB Connection Pool
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=10
