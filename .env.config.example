# Zenith Configuration Template
# Copy this file to .env.config and fill in the values

# General App Config
PORT=8080

# DB Connection Pool
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=10

# Generate a ConfigMap for local Kubernetes
# kubectl create configmap zenith-config --from-env-file=.env.config --dry-run=client -o yaml > .\deployments\k8s\local\config.yaml
#
# For production, you can set these environment variables in github actions or your deployment pipeline instead of using a ConfigMap.